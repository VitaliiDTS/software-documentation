# ─── Output Strategy ────────────────────────────────────────────────────────
# Allowed values: console | kafka
OUTPUT_TYPE=console

# ─── Data Source ─────────────────────────────────────────────────────────────
DATA_FILE_PATH=./data/jira-issues.json

# ─── Kafka Configuration (used only when OUTPUT_TYPE=kafka) ──────────────────
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=jira-issues
KAFKA_CLIENT_ID=jira-reporter
