<%- include('../partials/header', { title: 'All Issues' }) %>

<div class="page-header">
  <h1>Issues</h1>
  <a href="/issues/create" class="btn btn-primary">+ Create Issue</a>
</div>

<!-- Search & Filter -->
<form method="GET" action="/issues" class="filter-bar">
  <div class="form-group">
    <label>Search by title</label>
    <input type="text" name="search" value="<%= search %>" placeholder="Search issues...">
  </div>
  <div class="form-group" style="max-width:200px">
    <label>Filter by status</label>
    <select name="status">
      <option value="">All statuses</option>
      <% statuses.forEach(s => { %>
        <option value="<%= s %>" <%= selectedStatus === s ? 'selected' : '' %>><%= s %></option>
      <% }) %>
    </select>
  </div>
  <div style="display:flex;gap:6px;align-items:flex-end;padding-bottom:2px">
    <button type="submit" class="btn btn-primary">Filter</button>
    <% if (search || selectedStatus) { %>
      <a href="/issues" class="btn btn-secondary">Clear</a>
    <% } %>
  </div>
</form>

<% if (issues.length === 0) { %>
  <div class="card" style="text-align:center;padding:40px">
    <p class="text-muted">No issues found.</p>
    <a href="/issues/create" class="btn btn-primary mt-2">Create the first issue</a>
  </div>
<% } else { %>
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Title</th>
        <th>Status</th>
        <th>Priority</th>
        <th>Assignee</th>
        <th>Project</th>
        <th>Due Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% issues.forEach(issue => { %>
        <tr>
          <td class="text-muted"><%= issue.id %></td>
          <td><strong><%= issue.title %></strong></td>
          <td>
            <%
              const statusClass = {
                'To Do': 'badge-todo',
                'In Progress': 'badge-inprog',
                'Done': 'badge-done'
              }[issue.status] || 'badge-todo';
            %>
            <span class="badge <%= statusClass %>"><%= issue.status %></span>
          </td>
          <td>
            <%
              const prioClass = {
                'Low': 'badge-low',
                'Medium': 'badge-medium',
                'High': 'badge-high'
              }[issue.priority] || 'badge-low';
            %>
            <span class="badge <%= prioClass %>"><%= issue.priority %></span>
          </td>
          <td><%= issue.assigneeName %></td>
          <td><%= issue.projectName %></td>
          <td class="text-muted">
            <%= issue.dueDate ? new Date(issue.dueDate).toLocaleDateString('en-GB') : '—' %>
          </td>
          <td>
            <div class="actions">
              <a href="/issues/<%= issue.id %>" class="btn btn-secondary btn-sm">Details</a>
              <a href="/issues/<%= issue.id %>/edit" class="btn btn-warning btn-sm">Edit</a>
              <a href="/issues/<%= issue.id %>/delete" class="btn btn-danger btn-sm">Delete</a>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <p class="text-muted mt-2">Showing <%= issues.length %> issue<%= issues.length !== 1 ? 's' : '' %></p>
<% } %>

<%- include('../partials/footer') %>
